# dependencies
node_modules

# build output
dist

# raw source videos (originals are too large for git;
# web-optimized clips live in public/videos and ARE committed)
videos/*
!videos/.gitkeep

# raw logo source assets (originals; production logos are inline SVG in src/components/Logos.tsx)
Logos/

# typescript incremental build info
*.tsbuildinfo

# tsc-emitted config artifacts (source of truth is vite.config.ts)
vite.config.js
vite.config.d.ts

# env / secrets
.env
.env.local
.env.*.local
.vercel

# os / editor
.DS_Store
Thumbs.db
.idea
.vscode
